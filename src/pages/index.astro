---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Mivu — The Sport-Native Attention Engine</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
<div
	class="mx-auto grid min-h-screen max-w-[1400px] grid-rows-[auto_1fr] px-[clamp(1.5rem,6vw,5rem)] pt-[clamp(1.12rem,2.8vw,2.24rem)] pb-[clamp(2rem,5vw,4rem)]"
>
			<header class="flex items-center justify-between border-b border-paper/10 pb-7">
				<a href="#" class="block">
					<svg
						height="52"
						viewBox="0 0 220 90"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
						aria-label="Mivu Studios"
					>
						<rect x="0" y="0" width="220" height="54" fill="#f5f2ed"></rect>
						<text
							x="110"
							y="42"
							font-family="'Arial Black', Arial, sans-serif"
							font-weight="900"
							font-size="42"
							fill="#0a0a0a"
							text-anchor="middle"
							letter-spacing="2">MIVU</text
						>
						<text
							x="110"
							y="84"
							font-family="'Arial Black', Arial, sans-serif"
							font-weight="900"
							font-size="28"
							fill="#f5f2ed"
							text-anchor="middle"
							letter-spacing="4">STUDIOS</text
						>
					</svg>
				</a>
				<span
					class="hidden rounded-full border border-acid/30 px-4 py-1.5 text-[0.72rem] font-medium uppercase tracking-[0.18em] text-acid sm:inline-block"
				>
					Get in touch
				</span>
			</header>

<main
	class="hero-decoration relative flex flex-col justify-center gap-6 py-[clamp(1.12rem,4.48vh,2.24rem)]"
>
				<p
					class="animate-fade-up text-[1rem] font-light uppercase tracking-[0.22em] text-paper/85 [animation-delay:0.1s]"
				>
					Sport · Entertainment · Fan Engagement
				</p>

				<h1
					class="animate-fade-up max-w-[14ch] font-display text-[clamp(4.5rem,11vw,11rem)] leading-[0.88] tracking-[0.02em] [animation-delay:0.2s]"
				>
					Where fans<br />
					<em class="block not-italic text-acid">feel it.</em>
				</h1>

				<div class="animate-fade-up flex items-center gap-6 [animation-delay:0.35s]">
					<div class="h-px max-w-20 flex-1 bg-paper/20"></div>
				</div>

				<p
					class="animate-fade-up max-w-[65ch] text-[clamp(1rem,1.8vw,1.25rem)] font-light leading-[1.65] text-paper/70 [animation-delay:0.45s]"
				>
					A <strong class="font-medium text-paper">sport-native attention engine</strong> brands can
					tap instantly — built for the pulse of live sport, the energy of the crowd, and the moments
					that move people.
				</p>

				<p
					class="animate-fade-up max-w-[65ch] text-[clamp(1rem,1.8vw,1.25rem)] font-normal leading-[1.6] text-paper/85 [animation-delay:0.52s]"
				>
					We turn stars' global fanbase into a <strong class="font-medium text-acid"
						>competitive digital army.</strong
					>
				</p>

				<p
					class="animate-fade-up max-w-[65ch] font-display text-[clamp(1.8rem,3.5vw,2.8rem)] leading-[1] tracking-[0.04em] text-paper [animation-delay:0.6s]"
				>
					Your fans don't just follow you —<br />they <em class="not-italic text-acid">play</em> for
					you.
				</p>
				
					<div class="flex flex-col gap-1">
					<span class="mt-2 text-[0.72rem] uppercase tracking-[0.18em] text-paper/65">
						Get in touch
					</span>

					<a
						href="mailto:hello@mivu.com"
						class="border-b border-acid/35 pb-2.5 text-[clamp(1.1rem,2vw,1.35rem)] font-medium tracking-[0.01em] text-acid transition-colors hover:border-paper/50 hover:text-paper"
					>
						hello@mivu.com
					</a>
				</div>

				<footer
					class="mt-0 flex w-full items-center justify-between pt-[0.25rem]"
				>
					<span class="text-xs tracking-[0.06em] text-paper/55 text-right">
						© 2026 MIVU STUDIOS
					</span>
					<span class="text-xs uppercase tracking-[0.14em] text-paper/55">
						Sport · Gaming · Live
					</span>

				
				</footer>
			</main>
		</div>
	</body>
</html>
