---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<title>Mivu — The Sport-Native Attention Engine</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body class="relative overflow-x-hidden text-paper">
		<!-- Background image -->
		<div
			class="pointer-events-none fixed inset-0 -z-20 bg-[url('/images/background_mivu.png')] bg-cover bg-center bg-no-repeat opacity-[0.5]"
		></div>

		<div
			class="mx-auto grid min-h-screen max-w-[1170px] grid-rows-[auto_1fr] px-[clamp(1.254rem,5.016vw,4.18rem)] pt-[clamp(0.936rem,2.341vw,1.873rem)] pb-[clamp(1.672rem,4.18vw,3.344rem)]"
		>
			<header
				class="flex items-center justify-between border-b border-paper/15 pb-[1.463rem]"
			>
				<a href="#" class="block">
					<img
						src="/images/mivu-logo.svg"
						alt="MIVU"
						height="57"
						class="block h-[42.75px] w-auto sm:h-[57px]"
					/>
				</a>

				<span
					class="hidden rounded-full border border-acid/30 px-[0.836rem] py-[0.314rem] text-[0.6019rem] font-medium uppercase tracking-[0.18em] text-acid sm:inline-block"
				>
					Get in touch
				</span>
			</header>

			<main
				class="relative flex min-w-0 flex-col gap-[clamp(1.425rem,2.85vh,2.375rem)] py-[clamp(0.936rem,3.745vh,1.873rem)] portrait:pt-[clamp(0.475rem,2.85vh,1.425rem)] sm:portrait:pt-[clamp(1.9rem,5.7vh,3.8rem)]"
			>
				<div
					class="animate-fade-up w-full min-w-0 overflow-hidden [animation-delay:0.1s]"
				>
					<div class="flex w-max animate-marquee">
						<p
							class="whitespace-nowrap pr-[clamp(1.9rem,3.8vw,3.8rem)] text-[clamp(1.14rem,1.2825vw,2.47rem)] font-light uppercase tracking-[0.75em] text-paper/50"
						>
							Sport · Entertainment · Fan Engagement
						</p>
						<p
							aria-hidden="true"
							class="whitespace-nowrap pr-[clamp(1.9rem,3.8vw,3.8rem)] text-[clamp(1.14rem,1.2825vw,2.47rem)] font-light uppercase tracking-[0.75em] text-paper/50"
						>
							Sport · Entertainment · Fan Engagement
						</p>
					</div>
				</div>

				<div
					class="animate-fade-up flex items-center justify-between [animation-delay:0.15s]"
				>
					<span
						class="h-px w-[clamp(57px,9.5vw,76px)] bg-paper/30"
					></span>
					<span
						class="h-px w-[clamp(57px,9.5vw,76px)] bg-paper/30"
					></span>
				</div>

				<div
					class="animate-fade-up py-[28.5px] pb-[9.5px] grid grid-cols-[auto_1fr] items-start gap-x-[clamp(1.235rem,2.85vw,2.85rem)] pl-0 sm:pl-[38px] [animation-delay:0.2s]"
				>
					<span
						class="col-start-1 row-start-1 font-display text-[clamp(4.712rem,11.096vw,11.096rem)] font-bold leading-[0.88] tracking-[0.02em]"
					>
						Where
					</span>

					<p
						class="col-start-2 row-start-1 self-start pt-[3.7em] text-[clamp(1.42rem,1.52vw,1.1875rem)] uppercase leading-[1.2] tracking-[0.04em] portrait:col-span-2 portrait:col-start-1 portrait:row-start-3 portrait:pt-0 portrait:mt-[clamp(0.7125rem,2.85vh,1.9rem)]"
					>
						Your fans don't just follow you.<br />
						They play for you.
					</p>

					<div
						class="col-span-2 row-start-2 flex flex-wrap items-baseline gap-x-[clamp(0.76rem,1.52vw,1.425rem)] font-display text-[clamp(4.712rem,11.096vw,11.096rem)] font-bold leading-[0.88] tracking-[0.02em]"
					>
						<span>Fans</span>
						<span class="text-acid">Feel It</span>
					</div>
				</div>

				<div
					class="animate-fade-up flex items-center justify-between [animation-delay:0.35s]"
				>
					<span
						class="h-px w-[clamp(57px,9.5vw,76px)] bg-paper/30"
					></span>
					<span
						class="h-px w-[clamp(57px,9.5vw,76px)] bg-paper/30"
					></span>
				</div>

				<p
					class="animate-fade-up py-[4.75px] max-w-[65ch] text-[clamp(0.836rem,1.5048vw,1.045rem)] font-light leading-[1.6] text-paper/70 [animation-delay:0.45s]"
				>
					A
					<strong class="font-medium text-paper">
						sport-native attention engine
					</strong>
					brands can tap instantly.
					<br />
					Built for the pulse of live sport, the energy of the crowd,
					and the moments that move people.
				</p>

				<p
					class="animate-fade-up max-w-[65ch] text-[clamp(0.836rem,1.5048vw,1.045rem)] font-normal leading-[1.6] text-paper/85 [animation-delay:0.52s]"
				>
					We turn stars' global fanbase into a
					<strong class="font-medium text-acid">
						competitive digital army.
					</strong>
				</p>

				<footer
					class="border-t border-paper/15 animate-fade-up mt-auto grid grid-cols-2 items-center gap-x-4 gap-y-3 pt-[0.95rem] sm:grid-cols-3 sm:gap-y-0 [animation-delay:0.6s]"
				>
					<span
						class="col-start-1 row-start-2 text-[0.66rem] tracking-[0.06em] text-paper/55 sm:row-start-1"
					>
						© 2026 MIVU STUDIOS INC.| All rights reserved
					</span>

					<div class="col-span-2 row-start-1 flex items-center justify-center gap-3 sm:col-span-1 sm:col-start-2"> <span class="text-[0.66rem] uppercase tracking-[0.18em] text-paper/55">
Get in touch
</span> <a href="mailto:hello@mivu.com" class="border-b border-acid/35 text-[0.72rem] font-medium tracking-[0.01em] text-acid transition-colors hover:border-paper/50 hover:text-paper">
hello@mivu.com
</a> </div>

					<span
						class="col-start-2 row-start-2 text-right text-[0.66rem] uppercase tracking-[0.14em] text-paper/55 sm:col-start-3 sm:row-start-1"
					>
						Sport · Gaming · Live
					</span>
				</footer>
			</main>
		</div>
	</body>
</html>